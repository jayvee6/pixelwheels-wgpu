{
  "name": "pixelwheels-wgpu",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "WebGPU port of Pixel Wheels (https://github.com/agateau/pixelwheels) — vertical slice",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "assets:img": "node tools/build-assets.mjs",
    "assets:map": "node tools/build-map.mjs",
    "assets:map:country": "MAP_NAME=country node tools/build-map.mjs",
    "assets:map:snow2": "MAP_NAME=snow2 TSX_NAME=snow node tools/build-map.mjs",
    "assets:map:snow3": "MAP_NAME=snow3 TSX_NAME=snow node tools/build-map.mjs",
    "assets:map:flood": "MAP_NAME=flood TSX_NAME=country node tools/build-map.mjs",
    "assets:map:river": "MAP_NAME=river TSX_NAME=country node tools/build-map.mjs",
    "assets:map:be": "MAP_NAME=be TSX_NAME=city node tools/build-map.mjs",
    "assets:map:city3": "MAP_NAME=city3 TSX_NAME=city node tools/build-map.mjs",
    "assets:map:tiny-sur-mer": "MAP_NAME=tiny-sur-mer TSX_NAME=city node tools/build-map.mjs",
    "assets:vehicles": "node tools/build-vehicles.mjs",
    "assets": "npm run assets:img && npm run assets:map && npm run assets:map:country && npm run assets:map:snow2 && npm run assets:map:snow3 && npm run assets:map:flood && npm run assets:map:river && npm run assets:map:be && npm run assets:map:city3 && npm run assets:map:tiny-sur-mer && npm run assets:vehicles",
    "eval": "npx tsx tools/eval.ts",
    "sweep": "node tools/sweep.mjs"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.40",
    "fflate": "^0.8.2",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "planck": "^1.0.0"
  }
}
